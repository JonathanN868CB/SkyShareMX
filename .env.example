# SkyShare Maintenance Portal Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Application URLs
# Point the production base URL to the SkyShareMX domain used by Supabase + auth redirects.
VITE_SITE_URL=https://skysharemx.com
# Leave VITE_PUBLIC_SITE_URL empty in local development to fall back to window.location.origin.
# Netlify preview builds can set this to ${DEPLOY_PRIME_URL} automatically.
VITE_PUBLIC_SITE_URL=
SITE_URL=https://skysharemx.com
# Optional: Enable the Lovable editor overlay on *.lovable.app preview domains only.
VITE_LOVABLE_EDIT_ENABLED=false
# Optional: Additional hostnames that should be treated as development/preview
# VITE_DEV_HOSTS=preview.skyshare-maintenance.netlify.app

