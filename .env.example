# SkyShare Maintenance Portal Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Application URLs
SITE_URL=https://maintenance.skyshare.com
# Optional: Additional hostnames that should be treated as development/preview
# VITE_DEV_HOSTS=preview.maintenance.skyshare.com

# Invitation email function (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=jonathan@skyshare.com
SMTP_PASS=
SMTP_FROM="SkyShare Maintenance Portal <jonathan@skyshare.com>"
# Optionally override the Netlify function endpoint in local development
# VITE_INVITE_FUNCTION_URL=http://localhost:8888/.netlify/functions/send-user-invitation
